APP_NAME=Beacon
DATABASE_URL=sqlite:///./beacon.db
DATABASE_RUN_MIGRATIONS_ON_STARTUP=true
ENVIRONMENT=development
CONTROL_API_KEY=
CONTROL_ALLOWED_IPS=127.0.0.1,::1,testclient
TRUSTED_HOSTS=127.0.0.1,localhost,testserver,testclient
CORS_ALLOWED_ORIGINS=
CORS_ALLOWED_ORIGIN_REGEX=
CORS_ALLOW_CREDENTIALS=true
HTTPS_REDIRECT_ENABLED=false
GZIP_MINIMUM_SIZE=500
FEE_RATE=0.001
NEWS_SENTIMENT_BIAS=0

BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_BASE_URL=https://api.binance.com
BINANCE_HTTP_TRUST_ENV=true
COINBASE_BASE_URL=https://api.exchange.coinbase.com
COINBASE_HTTP_TRUST_ENV=true
KRAKEN_BASE_URL=https://api.kraken.com
KRAKEN_HTTP_TRUST_ENV=true
OKX_BASE_URL=https://www.okx.com
OKX_HTTP_TRUST_ENV=true
MARKET_DATA_PROVIDER=auto
MARKET_DATA_SYMBOL=
EXECUTION_PROVIDER=binance

TRADING_SYMBOL=BTCUSDT
CANDLE_INTERVAL=15m
CANDLE_LIMIT=150
STRATEGY_CANDLE_MODE=15m
RSI_PERIOD=14
RSI_BUY_THRESHOLD=30
RSI_SELL_THRESHOLD=70
TRADE_AMOUNT_USDT=50
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_SEND_HOLD=true
DRY_RUN=true

AUTO_TRADING_ENABLED=false
POLL_INTERVAL_SECONDS=300
RECONCILIATION_ENABLED=false
RECONCILIATION_INTERVAL_SECONDS=120

MT5_TERMINAL_PATH=C:\Program Files\MetaTrader 5\terminal64.exe
MT5_PROFILE_ENCRYPTION_KEY=
MT5_RUNTIME_OWNER_ID=local
MT5_EXECUTION_MODE=direct
MT5_WORKER_POLL_SECONDS=5
MT5_WORKER_CLAIM_TIMEOUT_SECONDS=120
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_SYMBOL=BTCUSD
MT5_SYMBOLS=EURUSD,GBPUSD,USDJPY,USDCHF,AUDUSD,USDCAD,NZDUSD
MT5_VOLUME_LOTS=0.01
MT5_DEVIATION=20
MT5_MAGIC=20260325
MOBILE_SESSION_DAYS=30
MOBILE_MAX_ACTIVE_SESSIONS_PER_USER=5
MOBILE_SESSION_RETENTION_DAYS=7
MOBILE_AUTH_RATE_LIMIT_WINDOW_SECONDS=60
MOBILE_AUTH_RATE_LIMIT_MAX_ATTEMPTS=10
PRO_ANALYSIS_EXECUTION_ENABLED=false
PRO_ANALYSIS_EXECUTION_MIN_VOTE_CONFIDENCE=0.68
PRO_ANALYSIS_EXECUTION_MIN_RR=2.0
PRO_ANALYSIS_EXECUTION_TRADING_STYLE=DAY TRADING
PRO_ANALYSIS_EXECUTION_RISK_TOLERANCE=MEDIUM
PRO_ANALYSIS_EXECUTION_REQUIRE_SESSION_FILTER=true
PRO_ANALYSIS_EXECUTION_REQUIRE_HIGHER_TIMEFRAME_ALIGNMENT=true
PRO_ANALYSIS_EXECUTION_REQUIRE_VWAP_ALIGNMENT=true
