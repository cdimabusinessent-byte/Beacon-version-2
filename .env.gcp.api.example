APP_NAME=Beacon
ENVIRONMENT=production

# Cloud Run / GCP API tier baseline
DATABASE_URL=postgresql+psycopg://beacon_user:change_me@YOUR_CLOUD_SQL_HOST:5432/beacon
DATABASE_RUN_MIGRATIONS_ON_STARTUP=true
CONTROL_API_KEY=replace-with-random-secret
CONTROL_ALLOWED_IPS=127.0.0.1,::1
TRUSTED_HOSTS=your-api-domain.run.app,your-api-domain.example.com
CORS_ALLOWED_ORIGINS=https://your-frontend.example.com
CORS_ALLOWED_ORIGIN_REGEX=
CORS_ALLOW_CREDENTIALS=true
HTTPS_REDIRECT_ENABLED=false
GZIP_MINIMUM_SIZE=500

# Keep market data Linux-safe on Cloud Run. Do not use MT5 market data in the API tier.
MARKET_DATA_PROVIDER=auto
MARKET_DATA_SYMBOL=
EXECUTION_PROVIDER=MT5
DRY_RUN=false
LIVE_TRADING_ARMED=false
AUTO_TRADING_ENABLED=false
STARTUP_SELF_CHECK_REQUIRED=false
RECONCILIATION_ENABLED=false
RECONCILIATION_INTERVAL_SECONDS=30

TRADING_SYMBOL=GBPUSDm
CANDLE_INTERVAL=1h
STRATEGY_CANDLE_MODE=1h
CANDLE_LIMIT=1000
RSI_PERIOD=14
RSI_BUY_THRESHOLD=28
RSI_SELL_THRESHOLD=72
TRADE_AMOUNT_USDT=50
STRICT_NO_REENTRY_ENABLED=true
STRICT_CANDLE_CLOSE_ENABLED=false
RISK_MIN_SECONDS_BETWEEN_TRADES=3600
STRATEGY_MIN_CONFIDENCE_THRESHOLD=0.60
STRATEGY_SIDE_CONFIDENCE_THRESHOLDS_ENABLED=true
STRATEGY_MIN_CONFIDENCE_THRESHOLD_BUY=0.60
STRATEGY_MIN_CONFIDENCE_THRESHOLD_SELL=0.30
RISK_MAX_SPREAD_PIPS=2.0
RISK_DAILY_LOSS_LIMIT_PCT=3.0
RISK_MT5_MAX_ACTIVE_POSITIONS=5

# Queue mode is required for GCP API hosting because MT5 execution stays on Windows.
MT5_EXECUTION_MODE=queue
MT5_WORKER_POLL_SECONDS=5
MT5_WORKER_CLAIM_TIMEOUT_SECONDS=120
MT5_RUNTIME_OWNER_ID=local
MT5_PROFILE_ENCRYPTION_KEY=replace-with-fernet-key
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_TERMINAL_PATH=
MT5_SYMBOL=GBPUSDm
MT5_SYMBOLS=EURUSDm,GBPUSDm,USDJPYm,USDCHFm,AUDUSDm,USDCADm,NZDUSDm,EURJPYm,GBPJPYm,GBPCHFm,EURAUDm,EURGBPm,AUDJPYm,AUDCHFm,CADJPYm,CHFJPYm,NZDJPYm,XAUUSDm
MT5_LIVE_ORDER_SYMBOL_TOGGLE_ENABLED=false
MT5_LIVE_ORDER_TOGGLE_SYMBOLS=
MT5_LIVE_ORDER_ENABLED_SYMBOLS=
MT5_VOLUME_LOTS=0.01
MT5_DEVIATION=15
MT5_MAGIC=20260326

MOBILE_SESSION_DAYS=30
MOBILE_MAX_ACTIVE_SESSIONS_PER_USER=5
MOBILE_SESSION_RETENTION_DAYS=7
MOBILE_AUTH_RATE_LIMIT_WINDOW_SECONDS=60
MOBILE_AUTH_RATE_LIMIT_MAX_ATTEMPTS=10

TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_TARGETS=
TELEGRAM_SEND_HOLD=false

PRO_ANALYSIS_EXECUTION_ENABLED=false
PRO_ANALYSIS_EXECUTION_MIN_VOTE_CONFIDENCE=0.68
PRO_ANALYSIS_EXECUTION_MIN_RR=2.0
PRO_ANALYSIS_EXECUTION_TRADING_STYLE=DAY TRADING
PRO_ANALYSIS_EXECUTION_RISK_TOLERANCE=LOW
PRO_ANALYSIS_EXECUTION_REQUIRE_SESSION_FILTER=true
PRO_ANALYSIS_EXECUTION_REQUIRE_HIGHER_TIMEFRAME_ALIGNMENT=true
PRO_ANALYSIS_EXECUTION_REQUIRE_VWAP_ALIGNMENT=true

ATR_RECOVERY_ENABLED=true
ATR_RECOVERY_MT5_ONLY=true
ATR_RECOVERY_TOGGLE_SYMBOLS=EURUSDm,GBPUSDm,USDJPYm,USDCHFm,AUDUSDm,USDCADm,NZDUSDm,EURJPYm,GBPJPYm,GBPCHFm,EURAUDm,EURGBPm,AUDJPYm,AUDCHFm,CADJPYm,CHFJPYm,NZDJPYm,XAUUSDm
ATR_RECOVERY_ENABLED_SYMBOLS=
ATR_RECOVERY_LIVE_HEDGE_ENABLED=false
ATR_RECOVERY_TRAILING_MONITOR_ENABLED=false
ATR_RECOVERY_AUTO_REVERSAL_CLOSE=false
ATR_RECOVERY_HEDGE_MONITOR_INTERVAL_SECONDS=30
ATR_RECOVERY_HEDGE_COOLDOWN_SECONDS=300
ATR_RECOVERY_MAX_HEDGES_PER_CYCLE=1
ATR_RECOVERY_MIN_PRICE_DELTA_FOR_REHEDGE_ATR=0.25

NEWS_FILTER_ENABLED=true
NEWS_FILTER_PRE_EVENT_MINUTES=30
NEWS_FILTER_POST_EVENT_MINUTES=15
NEWS_FILTER_MIN_IMPACT=high
NEWS_CALENDAR_PROVIDER_URL=
NEWS_CALENDAR_TIMEOUT_SECONDS=3.0
NEWS_CALENDAR_CACHE_SECONDS=60
NEWS_FILTER_EVENTS_UTC=
