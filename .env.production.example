APP_NAME=Beacon
ENVIRONMENT=production

# Use PostgreSQL for production. Example:
# DATABASE_URL=postgresql+psycopg://beacon_user:change_me@db-host:5432/beacon
DATABASE_URL=
DATABASE_RUN_MIGRATIONS_ON_STARTUP=true

# Operator-only route protection
CONTROL_API_KEY=
CONTROL_ALLOWED_IPS=127.0.0.1,::1

# Public web/mobile API edge settings
TRUSTED_HOSTS=api.example.com
CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGIN_REGEX=
CORS_ALLOW_CREDENTIALS=true
HTTPS_REDIRECT_ENABLED=true
GZIP_MINIMUM_SIZE=500

# Market data and execution
MARKET_DATA_PROVIDER=MT5
EXECUTION_PROVIDER=MT5
DRY_RUN=false
LIVE_TRADING_ARMED=false
AUTO_TRADING_ENABLED=false
RECONCILIATION_ENABLED=true
RECONCILIATION_INTERVAL_SECONDS=30

# MT5 execution host settings
MT5_TERMINAL_PATH=C:\Program Files\MetaTrader 5\terminal64.exe
MT5_PROFILE_ENCRYPTION_KEY=
MT5_RUNTIME_OWNER_ID=local
MT5_EXECUTION_MODE=direct
MT5_WORKER_POLL_SECONDS=5
MT5_WORKER_CLAIM_TIMEOUT_SECONDS=120
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_SYMBOL=GBPUSD+
MT5_SYMBOLS=EURUSD+,GBPUSD+,USDJPY+
MT5_VOLUME_LOTS=0.01
MT5_DEVIATION=15
MT5_MAGIC=20260326

# Mobile auth and session controls
MOBILE_SESSION_DAYS=30
MOBILE_MAX_ACTIVE_SESSIONS_PER_USER=5
MOBILE_SESSION_RETENTION_DAYS=7
MOBILE_AUTH_RATE_LIMIT_WINDOW_SECONDS=60
MOBILE_AUTH_RATE_LIMIT_MAX_ATTEMPTS=10

# Optional outbound notifications. Add only after secret rotation.
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_TARGETS=

# Trading safeguards
STRICT_NO_REENTRY_ENABLED=true
STRICT_CANDLE_CLOSE_ENABLED=false
RISK_MIN_SECONDS_BETWEEN_TRADES=3600
RISK_DAILY_LOSS_LIMIT_PCT=3.0
RISK_MT5_MAX_ACTIVE_POSITIONS=5

# Personal testing path:
# Keep MT5_EXECUTION_MODE=direct so Beacon executes on the same Windows host.
# Multi-user path:
# Set MT5_EXECUTION_MODE=queue and run the dedicated worker with `python -m app.mt5_worker`.